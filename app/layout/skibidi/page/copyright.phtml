<style>
    .footer-atom-signature {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 5.5rem;
        overflow: hidden;
        isolation: isolate;
    }

    @keyframes atomOrbitA {
        from {
            transform: rotateX(74deg) rotateY(16deg) rotateZ(0deg);
        }

        to {
            transform: rotateX(434deg) rotateY(376deg) rotateZ(360deg);
        }
    }

    @keyframes atomOrbitB {
        from {
            transform: rotateX(52deg) rotateY(-36deg) rotateZ(0deg);
        }

        to {
            transform: rotateX(412deg) rotateY(324deg) rotateZ(360deg);
        }
    }

    @keyframes atomOrbitC {
        from {
            transform: rotateX(86deg) rotateY(10deg) rotateZ(0deg);
        }

        to {
            transform: rotateX(446deg) rotateY(370deg) rotateZ(360deg);
        }
    }

    .footer-signature .copyright-wrap #concept-atom .nucleus {
        display: none;
    }

    .footer-signature .copyright-wrap #concept-atom .electron-orbit {
        --size: 6rem;

        position: absolute;
        top: 50%;
        left: 50%;
        width: var(--size);
        height: var(--size);
        margin-left: calc(var(--size) / -2);
        margin-top: calc(var(--size) / -2);
        border: 0;
        border-radius: 50%;
        box-shadow: none;
        transform-style: preserve-3d;
        will-change: transform;
        overflow: visible;
    }

    .footer-signature .copyright-wrap #concept-atom .electron-orbit::before,
    .footer-signature .copyright-wrap #concept-atom .electron-orbit::after {
        content: "";
        position: absolute;
        inset: 0;
        border: 0.0625rem solid rgba(244, 124, 43, 0.36);
        border-radius: 50%;
        box-shadow: inset 0 0 0.45rem rgba(221, 101, 21, 0.14);
    }

    .footer-signature .copyright-wrap #concept-atom .electron-orbit::before {
        clip-path: inset(0 0 50% 0);
        opacity: 0.65;
        z-index: 1;
    }

    .footer-signature .copyright-wrap #concept-atom .electron-orbit::after {
        clip-path: inset(50% 0 0 0);
        opacity: 0.95;
        z-index: 3;
    }

    .footer-signature .copyright-wrap #concept-atom .orbit-a {
        --size: 3rem;
        animation: atomOrbitA 6.8s linear infinite;
    }

    .footer-signature .copyright-wrap #concept-atom .orbit-b {
        --size: 4.1rem;
        animation: atomOrbitB 9.7s linear infinite reverse;
    }

    .footer-signature .copyright-wrap #concept-atom .orbit-c {
        --size: 5.3rem;
        animation: atomOrbitC 12.9s linear infinite;
    }

    .footer-signature {
        position: relative;
        display: inline-flex;
        align-items: center;
        color: var(--color-text-soft);
        z-index: 1;
    }

    .footer-signature .copyright-wrap {
        position: relative;
        width: 5.3rem;
        height: 5.3rem;
        flex: 0 0 1.5rem;
        perspective: 46.875rem;
        transform-style: preserve-3d;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .footer-signature .copyright-core {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.45rem;
        height: 1.45rem;
        border-radius: 50%;
        color: var(--color-text-soft);
        font-size: 1.1rem;
        font-weight: 300;
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%) translateZ(0.0625rem);
        z-index: 2;
    }
</style>

<div class="footer-atom-signature">
    <small class="footer-signature">
        <span class="copyright-wrap" aria-hidden="true">
            <div id="concept-atom">
                <div class="nucleus"></div>
                <div class="electron-orbit orbit-a"></div>
                <div class="electron-orbit orbit-b"></div>
                <div class="electron-orbit orbit-c"></div>
            </div>
            <span class="copyright-core">©</span>
        </span>
        <span></span>
    </small>
</div>